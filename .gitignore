# =============================================================================
# STM32 / Keil MDK — 编译产物与用户本地配置
# =============================================================================

# 编译输出目录
project/Objects/
project/Listings/

# 目标文件与链接产物
*.o
*.obj
*.crf
*.d
*.axf
*.elf
*.hex
*.bin
*.sct
*.lnp
*.dep
*.map
*.lst
*.iex

# Keil 构建日志与报告
*.build_log.htm
*.htm
build_log*.txt

# Keil 用户本地配置（窗口布局、断点、调试会话等，因人而异）
*.uvguix*
*.uvoptx

# Keil RTE 与调试配置（可由工程和 Pack 重新生成）
project/RTE/
project/DebugConfig/
*.dbgconf

# =============================================================================
# 工具链安装包（体积大，勿入库）
# =============================================================================
*.pack

# =============================================================================
# 编辑器 / IDE
# =============================================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# =============================================================================
# 操作系统
# =============================================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# =============================================================================
# 临时与备份
# =============================================================================
*~
*.bak
*.tmp
*.swp
*.swo

# =============================================================================
# 敏感信息
# =============================================================================
.env
.env.*
*.pem
*.key
credentials.json
